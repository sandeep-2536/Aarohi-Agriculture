<%- include('../layouts/header') %>
<link rel="stylesheet" href="/css/animals.css">

<section class="container">
  <% if (user && animal.owner && animal.owner._id.toString() === user._id.toString()) { %>
  <form action="/animals/<%= animal._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this listing?');">
    <button type="submit" class="btn danger">🗑 Delete Listing</button>
  </form>
<% } %>

  <h2><%= animal.type %> — ₹<%= animal.price %></h2>

  <div class="gallery">
    <% if (animal.images && animal.images.length > 0) { %>
      <% animal.images.forEach(img => { %>
        <img src="/uploads/<%= img %>" class="gallery-img" />
      <% }) %>
    <% } else { %>
      <img src="/images/noimage.png" class="gallery-img" />
    <% } %>
  </div>

  <p><strong>Breed:</strong> <%= animal.breed %></p>
  <p><strong>Age:</strong> <%= animal.age %> years</p>
  <p><strong>Description:</strong> <%= animal.description %></p>

  <h3>Seller</h3>
  <p><strong>Name:</strong> <%= animal.owner ? animal.owner.name : 'Unknown' %></p>
  <p><strong>Phone:</strong> <%= animal.ownerPhone %></p>

  <!-- Direct phone call to Indian number -->
  <a href="tel:<%= animal.ownerPhone %>" class="btn btn-call">📞 Call Farmer</a>

  <!-- optional: go back -->
  <a href="/animals" class="btn btn-secondary">Back to listings</a>
</section>

<%- include('../layouts/footer') %>
