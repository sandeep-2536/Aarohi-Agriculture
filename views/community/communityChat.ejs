<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farmers Group Chat - Aarohi Agriculture</title>
    <link rel="stylesheet" href="/css/output.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="bg-gray-50">

<%- include("../layouts/header") %>

<div class="max-w-7xl mx-auto px-4 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 h-[calc(100vh-200px)]">
        
        <!-- Sidebar -->
        <aside class="lg:col-span-1 bg-white rounded-2xl shadow-lg p-6 overflow-y-auto">
            
            <!-- Group Info -->
            <div class="text-center mb-6 pb-6 border-b border-gray-200">
                <div class="bg-linear-to-br from-green-500 to-green-600 w-20 h-20 rounded-full mx-auto mb-4 flex items-center justify-center">
                    <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
                    </svg>
                </div>
                <h2 class="text-xl font-bold text-gray-800 mb-1">Farmers Group 🌾</h2>
                <p class="text-sm text-gray-600">Ask, share, learn together</p>
            </div>

            <!-- My Profile -->
            <div class="bg-linear-to-br from-green-50 to-blue-50 rounded-xl p-4 mb-6">
                <div class="flex items-center gap-3">
                    <img src="<%= user.profileImage || '/images/default-user.png' %>" alt="You" class="w-12 h-12 rounded-full object-cover border-2 border-green-500">
                    <div class="flex-1">
                        <p class="font-bold text-gray-800"><%= user.name %></p>
                        <p class="text-xs text-gray-600"><%= user.village ? user.village + ', ' + user.state : user.mobileNumber %></p>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <button id="refreshBtn" class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-3 rounded-xl transition mb-4">
                <svg class="w-5 h-5 inline-block mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/>
                </svg>
                Refresh Chat
            </button>

            <!-- Info -->
            <div class="bg-blue-50 rounded-xl p-4 border border-blue-200">
                <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                    </svg>
                    <div class="text-xs text-gray-700">
                        <p class="font-semibold mb-1">Community Guidelines</p>
                        <ul class="space-y-1 text-gray-600">
                            <li>• Be respectful</li>
                            <li>• Share knowledge</li>
                            <li>• Help fellow farmers</li>
                        </ul>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Chat Main -->
        <main class="lg:col-span-3 bg-white rounded-2xl shadow-lg flex flex-col">
            
            <!-- Chat Header -->
            <div class="bg-linear-to-r from-green-600 to-green-700 text-white px-6 py-4 rounded-t-2xl">
                <h1 class="text-2xl font-bold mb-1">Group Discussion</h1>
                <p class="text-sm text-green-100">Ask about seeds, pests, fertilizers — share pictures</p>
            </div>

            <!-- Messages Area -->
            <div id="messages" class="flex-1 overflow-y-auto p-6 space-y-4">
                <% messages.forEach(msg => { %>
                    <div class="flex gap-3 <%= (msg.user._id.toString() === user._id.toString()) ? 'flex-row-reverse' : '' %>" data-id="<%= msg._id %>">
                        
                        <!-- Avatar -->
                        <img src="<%= msg.user.profileImage || '/images/default-user.png' %>" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="<%= msg.user.name %>">
                        
                        <!-- Message Content -->
                        <div class="flex-1 max-w-xl">
                            <div class="flex items-center gap-2 mb-1 <%= (msg.user._id.toString() === user._id.toString()) ? 'flex-row-reverse' : '' %>">
                                <span class="font-semibold text-gray-800 text-sm"><%= msg.user.name %></span>
                                <span class="text-xs text-gray-500"><%= new Date(msg.createdAt).toLocaleString() %></span>
                            </div>
                            
                            <!-- Message Bubble -->
                            <div class="<%= (msg.user._id.toString() === user._id.toString()) ? 'bg-green-500 text-white' : 'bg-gray-100 text-gray-800' %> rounded-2xl px-4 py-3 shadow-sm">
                                <% if (msg.text) { %>
                                    <p class="text-sm"><%= msg.text %></p>
                                <% } %>
                                
                                <% if (msg.image) { %>
                                    <img src="<%= msg.image %>" alt="upload" class="mt-2 rounded-xl max-w-sm">
                                <% } %>
                            </div>
                            
                            <!-- Actions -->
                            <div class="flex gap-2 mt-2 <%= (msg.user._id.toString() === user._id.toString()) ? 'flex-row-reverse' : '' %>">
                                <% if (msg.user._id.toString() === user._id.toString()) { %>
                                    <button class="text-xs text-gray-500 hover:text-blue-600 edit-btn">Edit</button>
                                    <button class="text-xs text-gray-500 hover:text-red-600 delete-btn">Delete</button>
                                <% } %>
                                <button class="text-xs text-gray-500 hover:text-green-600 reply-btn">Reply</button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Input Area -->
            <form id="sendForm" class="border-t border-gray-200 p-4 bg-gray-50 rounded-b-2xl" enctype="multipart/form-data">
                <div class="flex items-end gap-3">
                    
                    <!-- Text Input -->
                    <div class="flex-1">
                        <textarea 
                            id="messageInput" 
                            placeholder="Type your message..."
                            rows="1"
                            class="w-full px-4 py-3 border-2 border-gray-300 rounded-xl focus:outline-none focus:border-green-500 focus:ring-4 focus:ring-green-100 resize-none transition"
                        ></textarea>
                    </div>

                    <!-- Image Upload -->
                    <label class="cursor-pointer bg-gray-200 hover:bg-gray-300 p-3 rounded-xl transition">
                        <input id="imageInput" type="file" accept="image/*" class="hidden" />
                        <svg class="w-6 h-6 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
                        </svg>
                    </label>

                    <!-- Voice Button -->
                    <button type="button" id="voiceBtn" class="bg-blue-500 hover:bg-blue-600 text-white p-3 rounded-xl transition">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M7 4a3 3 0 016 0v4a3 3 0 11-6 0V4zm4 10.93A7.001 7.001 0 0017 8a1 1 0 10-2 0A5 5 0 015 8a1 1 0 00-2 0 7.001 7.001 0 006 6.93V17H6a1 1 0 100 2h8a1 1 0 100-2h-3v-2.07z" clip-rule="evenodd"/>
                        </svg>
                    </button>

                    <!-- Send Button -->
                    <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-xl font-semibold transition">
                        Send
                    </button>
                </div>
            </form>

        </main>
    </div>
</div>

<%- include("../layouts/footer") %>

<script>
// Pass server data to client
window.CURRENT_USER = {
    _id: "<%- user._id %>",
    name: "<%- user.name %>",
    profileImage: "<%- user.profileImage || '/images/default-user.png' %>"
};

window.CHAT_ROOM = {
    id: "<%- room._id %>"
};
</script>

<script src="/js/chat.js"></script>
</body>
</html>