<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Dashboard</title>

    <link rel="stylesheet" href="/css/layout.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

<%- include("../layouts/header") %>

<div class="dashboard-container">

    <h1 class="dash-title">👨‍🌾 Welcome, <%= user.name %></h1>

    <div class="stats-box">
        <div class="stat-card">
            <h2><%= myProblems.length %></h2>
            <p>Your Reported Problems</p>
        </div>
    </div>

    <h2 class="section-title">📝 Your Problems</h2>

    <% if (myProblems.length === 0) { %>
        <p class="no-data">You have not reported any problems yet.</p>
    <% } %>

    <div class="problems-list">
        <% myProblems.forEach(p => { %>
            <div class="problem-card" onclick="location.href='/community/problems/<%= p._id %>'">
                
                <h3><%= p.text.substring(0, 100) %>...</h3>

                <% if (p.image) { %>
                    <img src="<%= p.image %>" class="problem-thumb">
                <% } %>

                <small class="date">
                    Posted on: <%= new Date(p.createdAt).toLocaleString() %>
                </small>

                <button class="btn-view">View Discussion</button>
            </div>
        <% }) %>
    </div>

</div>

<%- include("../layouts/footer") %>

</body>
</html>
