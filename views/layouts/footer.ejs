<script>
// Set current user data
var CURRENT_USER = null;
<%_ if (user) { _%>
CURRENT_USER = {
    _id: "<%- user._id %>",
    name: "<%- user.name %>",
    profileImage: "<%- user.profileImage || '/images/default-user.png' %>"
};
<%_ } _%>

window.CURRENT_USER = CURRENT_USER;

// Also provide a hidden DOM config for scripts that read dataset (incomingCall, farmer list etc.)
var incomingConfigDiv = document.createElement('div');
incomingConfigDiv.id = 'incomingConfig';
incomingConfigDiv.style.display = 'none';
incomingConfigDiv.dataset.userId = CURRENT_USER && CURRENT_USER._id ? CURRENT_USER._id : '';
incomingConfigDiv.dataset.userName = CURRENT_USER && CURRENT_USER.name ? CURRENT_USER.name : '';
document.body.appendChild(incomingConfigDiv);

// Render mobile profile link
(function() {
    var mobileProfileContainer = document.getElementById('mobileProfileLink');
    if (!mobileProfileContainer) return;
    
    var profileHTML = '';
    if (CURRENT_USER) {
        profileHTML = '<a href="/dashboard" class="flex flex-col items-center gap-1 px-4 py-2 text-gray-600 hover:text-green-600 transition-colors">' +
            '<img src="' + CURRENT_USER.profileImage + '" class="w-6 h-6 rounded-full object-cover border-2 border-green-600" alt="Profile">' +
            '<span class="text-xs font-medium">Profile</span>' +
            '</a>';
    } else {
        profileHTML = '<a href="/auth/login" class="flex flex-col items-center gap-1 px-4 py-2 text-gray-600 hover:text-green-600 transition-colors">' +
            '<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">' +
            '<path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zm-2 4a5 5 0 00-4.546 2.916A5.986 5.986 0 0010 16a5.986 5.986 0 004.546-2.084A5 5 0 0010 11z" clip-rule="evenodd"/>' +
            '</svg>' +
            '<span class="text-xs font-medium">Login</span>' +
            '</a>';
    }
    mobileProfileContainer.innerHTML = profileHTML;
})();

function startGlobalVoice() {
    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        var recognition = new SpeechRecognition();
        recognition.lang = 'en-IN';
        recognition.start();
        
        recognition.onresult = function(event) {
            var transcript = event.results[0][0].transcript.toLowerCase();
            
            if (transcript.includes('scheme')) {
                window.location.href = '/schemes';
            } else if (transcript.includes('community')) {
                window.location.href = '/community';
            } else if (transcript.includes('animal')) {
                window.location.href = '/animals';
            } else if (transcript.includes('crop')) {
                window.location.href = '/crops';
            } else if (transcript.includes('doctor') || transcript.includes('vet')) {
                window.location.href = '/tele-vet';
            } else if (transcript.includes('stock')) {
                window.location.href = '/stock';
            } else if (transcript.includes('home')) {
                window.location.href = '/';
            } else {
                localStorage.setItem('voiceQuery', transcript);
                window.location.href = '/ai/assistant';
            }
        };
        
        recognition.onerror = function() {
            alert('Voice recognition error. Please try again.');
        };
    } else {
        alert('Voice not supported in your browser');
    }
}
</script>
<script src="/js/incomingCall.js"></script>