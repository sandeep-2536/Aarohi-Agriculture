<%- include('../layouts/header') %>

<div class="max-w-6xl mx-auto px-4 py-8">

    <!-- TITLE -->
    <h2 class="text-3xl font-bold text-green-700 mb-6 flex items-center gap-2">
        📦 Where is the Stock?
    </h2>

    <!-- Dealer Links -->
    <div class="flex gap-4 mb-6">
        <a href="/dealer-auth/register" class="text-blue-600 hover:underline">Dealer Register</a>
        <a href="/dealer-auth/login" class="text-blue-600 hover:underline">Dealer Login</a>
        <a href="/dealer" class="text-blue-600 hover:underline">Dealer Dashboard</a>
    </div>

    <!-- SEARCH BOX -->
    <form method="GET" action="/stock"
          class="bg-white p-5 rounded-xl shadow-md border border-gray-200 mb-10">

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">

            <!-- Query -->
            <input name="q"
                   type="text"
                   placeholder="Search e.g., Urea, Cotton Seed"
                   value="<%= query.q || '' %>"
                   class="w-full p-3 border rounded-xl focus:ring-2 focus:ring-green-400 outline-none">

            <!-- Category -->
            <select name="category"
                    class="w-full p-3 border rounded-xl focus:ring-2 focus:ring-green-400 outline-none">
                <option value="">All Categories</option>
                <option value="Seed" <%= query.category==='Seed'?'selected':''%>>Seed</option>
                <option value="Fertilizer" <%= query.category==='Fertilizer'?'selected':''%>>Fertilizer</option>
                <option value="Pesticide" <%= query.category==='Pesticide'?'selected':''%>>Pesticide</option>
                <option value="Tools" <%= query.category==='Tools'?'selected':''%>>Tools</option>
            </select>

            <!-- District -->
            <input name="district"
                   placeholder="District"
                   value="<%= query.district || '' %>"
                   class="w-full p-3 border rounded-xl focus:ring-2 focus:ring-green-400 outline-none">

            <!-- Submit -->
            <button class="w-full bg-green-600 text-white p-3 rounded-xl hover:bg-green-700 transition">
                🔍 Search
            </button>

        </div>

    </form>

    <!-- STOCK RESULTS -->
    <% if (stocks.length === 0) { %>
        <p class="text-center text-gray-500 text-lg">No results found.</p>
    <% } %>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">

        <% stocks.forEach(s => { %>
            <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden hover:shadow-lg transition">

                <!-- Image -->
                <% if (s.image) { %>
                    <img src="/uploads/<%= s.image %>"
                         class="w-full h-48 object-cover">
                <% } else { %>
                    <div class="w-full h-48 bg-gray-100 flex items-center justify-center text-gray-400">
                        No Image
                    </div>
                <% } %>

                <!-- Info -->
                <div class="p-5">

                    <h4 class="text-xl font-bold text-gray-800 mb-1">
                        <%= s.title %>
                    </h4>

                    <p class="text-sm text-gray-600">
                        <b>Category:</b> <%= s.category %>
                    </p>

                    <p class="text-sm text-gray-600">
                        <b>Dealer:</b> <%= s.dealer ? (s.dealer.shopName || s.dealer.name) : 'N/A' %>
                    </p>

                    <p class="text-sm text-gray-600">
                        <b>Location:</b> <%= s.location.village %>, <%= s.location.district %>
                    </p>

                    <p class="text-green-700 text-lg font-bold mt-1">
                        ₹<%= s.price %> / <%= s.quantityUnit %>
                    </p>

                    <!-- Buttons -->
                    <div class="flex gap-3 mt-4">

                        <a href="/stock/<%= s._id %>"
                           class="w-1/2 bg-blue-600 text-white text-center py-2 rounded-xl hover:bg-blue-700 transition">
                            👁 View
                        </a>

                        <a href="tel:<%= s.phone %>"
                           class="w-1/2 bg-green-600 text-white text-center py-2 rounded-xl hover:bg-green-700 transition">
                            📞 Call
                        </a>

                    </div>

                </div>

            </div>
        <% }) %>

    </div>

    <a href="/" class="mt-10 block text-center text-blue-600 hover:underline text-lg">
        ← Back to Home
    </a>

</div>

<%- include('../layouts/footer') %>
