<%- include('../layouts/header') %>

<div class="max-w-4xl mx-auto px-4 py-8">

  <h2 class="text-3xl font-bold text-green-700 mb-4">
    🐮 Tele-Vet Dashboard
  </h2>

  <p class="text-gray-700 mb-2">Dr. <b><%= vet.name %></b></p>
  <p class="text-gray-600 mb-6">
    📞 <%= vet.phone %> | ⭐ <%= vet.specialization %>
  </p>

  <!-- Incoming Call Box -->
  <div id="incomingCallBox"
       class="hidden bg-white border border-gray-300 shadow-md rounded-xl p-6">

    <p id="incomingText" class="text-lg font-medium mb-4"></p>

    <div class="flex gap-4">
      <button id="acceptBtn"
              class="bg-green-600 text-white px-5 py-3 rounded-xl hover:bg-green-700">
        ✔ Accept
      </button>

      <button id="rejectBtn"
              class="bg-red-600 text-white px-5 py-3 rounded-xl hover:bg-red-700">
        ✖ Reject
      </button>
    </div>

  </div>

</div>

<script src="/socket.io/socket.io.js"></script>

<script>
  window.VET_DASH_CONFIG = {
    vetId: "<%= vet._id %>",
    vetName: "<%= vet.name %>"
  };
</script>

<script src="/js/teleVetVetDashboard.js"></script>

<%- include('../layouts/footer') %>
